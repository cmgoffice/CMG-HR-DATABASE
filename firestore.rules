rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /CMG-HR-Database/root {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /CMG-HR-Database/root/users/{uid} {
      allow read, write: if request.auth != null;
    }
    match /CMG-HR-Database/root/appMeta/{docId} {
      allow read, write: if request.auth != null;
    }
    match /CMG-HR-Database/root/activityLogs/{docId} {
      allow read, write: if request.auth != null;
    }
    match /CMG-HR-Database/root/{sub}/{docId} {
      allow read, write: if request.auth != null;
    }
    match /CMG-HR-Database/root/{sub}/{docId}/{rest=**} {
      allow read, write: if request.auth != null;
    }
  }
}
