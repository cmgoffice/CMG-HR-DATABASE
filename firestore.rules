rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read/write access to CMG-HR-Database collection and all subcollections
    match /CMG-HR-Database/{document=**} {
      allow read, write: if true;
    }
    
    // Allow read/write access to activity_logs for logging
    match /activity_logs/{document=**} {
      allow read, write: if true;
    }
    
    // Alternative: More secure rules with authentication (uncomment if needed)
    // match /CMG-HR-Database/{document=**} {
    //   allow read, write: if request.auth != null;
    // }
  }
}
